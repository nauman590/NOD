// NOD — Prisma schema. All money in integer cents.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum ProviderStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  DEACTIVATED
  REJECTED
}

enum JobStatus {
  AVAILABLE
  CLAIMED
  PENDING_APPROVAL
  APPROVED
  DECLINED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETE
  CANCELLED
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  DECLINED
}

enum PaymentType {
  BASE
  ADDON
  CANCELLATION_FEE
  PROVIDER_STRIKE
  PROVIDER_DEPOSIT
  DEPOSIT_DEDUCTION
  PAYOUT
  REFUND
  DISPUTE_CHARGE
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  AUTHORIZED
  CAPTURED
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
  CANCELLED
}

enum CancellationTier {
  BEFORE_CLAIM
  AFTER_CLAIM
  AFTER_EN_ROUTE
  NO_SHOW
}

enum CancelledBy {
  CUSTOMER
  PROVIDER
  ADMIN
  SYSTEM
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum NotificationChannel {
  SMS
  PUSH
  EMAIL
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum StrikeReason {
  NO_SHOW
  LATE_CANCEL
  LATE_ARRIVAL
  LOW_RATING
  OTHER
}

// (Strike model gains `settledAt` to mark fees already deducted from a payout.)

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  phone         String?  @unique
  phoneVerified Boolean  @default(false)
  // SMS opt-in (brief: defaults to checked, toggleable later). Twilio SMS is only sent
  // when this is true AND a phone is on file; IN_APP notifications always record.
  smsOptIn      Boolean  @default(true)
  // Phone verification OTP (hashed) + expiry. Set by /auth/phone/request-otp, cleared on verify.
  phoneOtpHash      String?
  phoneOtpExpiresAt DateTime?
  // Wrong-guess counter, persisted so the brute-force cap holds across API instances.
  phoneOtpAttempts  Int      @default(0)
  passwordHash  String?
  role          Role     @default(CUSTOMER)
  fullName      String?
  profilePhotoUrl String?
  isGuest       Boolean  @default(false)
  // Stripe Customer + the card saved at checkout (setup_future_usage=off_session), so
  // later off-session charges (add-ons, cancellation fees, dispute charges) can bill the
  // customer's real card instead of the test-mode default. Populated on first paid checkout.
  stripeCustomerId      String?
  stripePaymentMethodId String?
  // Aggregate of the ratings this user received AS A CUSTOMER (providers keep their
  // own aggregate on Provider). Lets a provider see a customer's reputation before
  // accepting the next job.
  customerRatingAvg   Float @default(0)
  customerRatingCount Int   @default(0)
  suspendedUntil DateTime?
  suspendedReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  provider      Provider?
  customerJobs  Job[]          @relation("CustomerJobs")
  sessions      Session[]
  passwordResetTokens PasswordResetToken[]
  ratingsGiven  Rating[]       @relation("RatingsGiven")
  ratingsGot    Rating[]       @relation("RatingsReceived")
  notifications Notification[]
  disputes      Dispute[]      @relation("DisputeRaisedBy")
  disputePhotos DisputePhoto[] @relation("DisputePhotoUploader")
  payments      Payment[]
  messages      Message[]      @relation("MessageSender")
  offPlatformReportsMade    OffPlatformReport[] @relation("OffPlatformReporter")
  offPlatformReportsAgainst OffPlatformReport[] @relation("OffPlatformReported")

  @@index([role])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([refreshTokenHash])
}

model Provider {
  id                    String         @id @default(cuid())
  userId                String         @unique
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                ProviderStatus @default(PENDING_APPROVAL)
  vehicleType           String?
  licenseUrl            String?
  profilePhotoUrl       String?
  bio                   String?
  stripeAccountId       String?
  stripeCustomerId      String?
  depositSetupId        String?
  depositPaymentIntentId String?
  depositRefundedAt     DateTime?
  depositStatus         PaymentStatus?
  // Live held-deposit balance in cents (set when the deposit is captured; drawn down as
  // strike fees / dispute claw-backs are settled from it; refunded amount on exit). Null
  // = no deposit ever collected.
  depositBalanceCents   Int?
  // Background check. Without a Checkr key this is a manual admin gate (STUB_PENDING →
  // PASSED/FAILED). With CHECKR_API_KEY set, checkrCandidateId/checkrReportId are
  // populated and the status is driven by Checkr report webhooks.
  backgroundCheckStatus String?        @default("STUB_PENDING")
  checkrCandidateId     String?
  checkrReportId        String?
  approvedAt            DateTime?
  approvedById          String?
  ratingAvg             Float          @default(0)
  ratingCount           Int            @default(0)
  suspendedUntil        DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  categoryRates ProviderCategoryRate[]
  claimedJobs   Job[]                  @relation("ProviderJobs")
  strikes       Strike[]
  adjustments   Adjustment[]
  clawbacks     DisputeClawback[]

  @@index([status])
}

model Category {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  name                  String
  active                Boolean  @default(true)
  sortOrder             Int      @default(0)
  promptTemplate        String
  intakeConfig          Json
  baseFeeCents          Int      @default(0)
  disposalFeeCents      Int      @default(0)
  perMileFeeCents       Int      @default(0)
  fallbackHourlyRateCents Int    @default(5000)
  minHours              Float    @default(0.5)
  maxHours              Float    @default(12)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  providerRates ProviderCategoryRate[]
  jobs          Job[]
  estimates     Estimate[]

  @@index([active])
}

model Estimate {
  id             String   @id @default(cuid())
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
  customerId     String?
  photoUrl       String?
  description    String
  intakeData     Json?
  serviceAddress String?
  distanceMiles  Float?
  estimatedHours Float
  avgRateCents   Int
  rateSource     String
  estimateSource String
  basePriceCents Int
  breakdown      Json
  suggestedAddOns Json?
  lockedUntil    DateTime
  inputsHash     String
  consumed       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([categoryId])
}

model ProviderCategoryRate {
  id              String   @id @default(cuid())
  providerId      String
  provider        Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  hourlyRateCents Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@unique([providerId, categoryId])
  @@index([categoryId, active])
}

model Job {
  id               String            @id @default(cuid())
  customerId       String
  customer         User              @relation("CustomerJobs", fields: [customerId], references: [id])
  categoryId       String
  category         Category          @relation(fields: [categoryId], references: [id])
  providerId       String?
  provider         Provider?         @relation("ProviderJobs", fields: [providerId], references: [id])
  status           JobStatus         @default(AVAILABLE)

  photoUrl         String?
  description      String
  intakeData       Json?
  serviceAddress   String?
  distanceMiles    Float?

  estimateId       String?
  estimatedHours   Float?
  basePriceCents   Int
  lockedPriceCents Int?
  lockedUntil      DateTime?

  providerLat      Float?
  providerLng      Float?
  etaMinutes       Int?      // live ETA, recomputed on every GPS ping (drives the map)
  dispatchEtaMinutes Int?    // ETA frozen at trip start — the baseline for late-arrival penalty

  claimedAt        DateTime?
  enRouteAt        DateTime?
  arrivedAt        DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  cancelledBy      CancelledBy?
  cancellationTier CancellationTier?
  cancellationReason String?         // free-text reason captured at cancel (brief B8)
  delayNoticeAt    DateTime?
  latePenaltyCents Int               @default(0)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  adjustments   Adjustment[]
  payments      Payment[]
  ratings       Rating[]
  disputes      Dispute[]
  notifications Notification[]
  messages      Message[]
  photos        JobPhoto[]
  offPlatformReports OffPlatformReport[]

  @@index([status])
  @@index([categoryId, status])
  @@index([providerId, status])
  @@index([lockedUntil])
}

model Adjustment {
  id          String           @id @default(cuid())
  jobId       String
  job         Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  providerId  String
  provider    Provider         @relation(fields: [providerId], references: [id])
  description String
  priceCents  Int
  status      AdjustmentStatus @default(PENDING)
  approvedAt  DateTime?
  declinedAt  DateTime?
  createdAt   DateTime         @default(now())

  @@index([jobId, status])
}

model Payment {
  id                    String        @id @default(cuid())
  jobId                 String?
  job                   Job?          @relation(fields: [jobId], references: [id])
  userId                String
  user                  User          @relation(fields: [userId], references: [id])
  type                  PaymentType
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  amountCents           Int
  platformFeeCents      Int           @default(0)
  providerNetCents      Int           @default(0)
  stripePaymentIntentId String?
  stripeChargeId        String?
  stripeRefundId        String?
  stripeTransferId      String?
  capturedAt            DateTime?
  refundedAmountCents   Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([jobId])
  @@index([userId])
  @@index([type, status])
}

model Rating {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  raterId   String
  rater     User     @relation("RatingsGiven", fields: [raterId], references: [id])
  rateeId   String
  ratee     User     @relation("RatingsReceived", fields: [rateeId], references: [id])
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([jobId, raterId])
  @@index([rateeId])
}

model Strike {
  id         String       @id @default(cuid())
  providerId String
  provider   Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  jobId      String?
  reason     StrikeReason
  feeCents   Int          @default(0)
  note       String?
  settledAt  DateTime?
  createdAt  DateTime     @default(now())

  @@index([providerId, createdAt])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String?
  job       Job?                @relation(fields: [jobId], references: [id])
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(QUEUED)
  template  String
  title     String
  body      String
  payload   Json?
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, readAt])
  @@index([jobId])
}

model Dispute {
  id           String        @id @default(cuid())
  jobId        String
  job          Job           @relation(fields: [jobId], references: [id])
  raisedById   String
  raisedBy     User          @relation("DisputeRaisedBy", fields: [raisedById], references: [id])
  status       DisputeStatus @default(OPEN)
  reason       String
  description  String?
  resolution   String?
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())

  photos       DisputePhoto[]
  clawbacks    DisputeClawback[]

  @@index([status])
  @@index([jobId])
}

// Evidence photos on a dispute. Either party (customer or provider) can attach them.
model DisputePhoto {
  id         String   @id @default(cuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  uploaderId String
  uploader   User     @relation("DisputePhotoUploader", fields: [uploaderId], references: [id])
  url        String
  createdAt  DateTime @default(now())

  @@index([disputeId])
}

// A ledger claw-back: when a dispute on an ALREADY-PAID-OUT job resolves to a refund,
// the refunded amount is recovered from the provider's next payout(s) — no Stripe
// transfer reversal. Mirrors the strike-fee settlement model.
model DisputeClawback {
  id          String    @id @default(cuid())
  disputeId   String
  dispute     Dispute   @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  amountCents Int
  settledAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([providerId, settledAt])
}

enum JobPhotoKind {
  BEFORE
  AFTER
}

model Message {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  senderId  String
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
}

model JobPhoto {
  id        String       @id @default(cuid())
  jobId     String
  job       Job          @relation(fields: [jobId], references: [id])
  kind      JobPhotoKind
  url       String
  lat       Float?
  lng       Float?
  takenAt   DateTime     @default(now())

  @@index([jobId])
}

enum OffPlatformReportStatus {
  PENDING
  VERIFIED
  DISMISSED
}

// A report that a job counterparty solicited an off-platform (cash / Venmo / etc.)
// payment. Reviewed by an admin; VERIFIED → the reported user is immediately banned.
model OffPlatformReport {
  id             String                  @id @default(cuid())
  jobId          String?
  job            Job?                    @relation(fields: [jobId], references: [id])
  reporterId     String
  reporter       User                    @relation("OffPlatformReporter", fields: [reporterId], references: [id])
  reportedUserId String
  reportedUser   User                    @relation("OffPlatformReported", fields: [reportedUserId], references: [id])
  description    String
  evidenceUrl    String?
  status         OffPlatformReportStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  banApplied     Boolean                 @default(false)
  createdAt      DateTime                @default(now())

  @@index([status])
  @@index([reportedUserId])
}

// Single-use, time-limited tokens for the password-reset flow. Only the SHA-256
// hash of the token is stored; the raw token lives only in the reset link.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}
