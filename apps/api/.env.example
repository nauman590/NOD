# --- Database ---
DATABASE_URL="postgresql://nod:PASSWORD@localhost:5433/nod?schema=public"

# --- Auth ---
JWT_ACCESS_SECRET="dev_access_secret_change_me"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL_DAYS="30"

# --- AI pricing / vision estimator ---
# The estimator sends the customer photo + category + description to a vision model.
# AI_PROVIDER selects it:
#   auto (default) → OpenAI if OPENAI_API_KEY is set, else Claude if ANTHROPIC_API_KEY
#                    is set, else the deterministic heuristic (app still prices w/o a key).
#   openai | anthropic | heuristic → force that provider.
AI_PROVIDER="auto"
# Display-latency SLA (ms). The brief requires a price within 5 seconds; if the model is
# slower, the instant heuristic is returned so the deadline is always met. 0 = wait fully.
AI_SLA_MS="5000"

# OpenAI vision. Leave empty to fall back per AI_PROVIDER above. Default gpt-4o-mini
# answers in ~2-3s (under the 5s SLA); "gpt-4o" is higher quality but ~6-9s, so raise
# AI_SLA_MS if you switch to it.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TIMEOUT_MS="20000"

# Anthropic Claude vision. Leave empty to fall back per AI_PROVIDER above.
ANTHROPIC_API_KEY=""
# Defaults to claude-opus-4-8. Set to a smaller model (e.g. claude-haiku-4-5) to trade
# some quality for lower latency/cost on the estimate call.
ANTHROPIC_MODEL="claude-opus-4-8"
ANTHROPIC_TIMEOUT_MS="20000"

# --- Stripe (test mode) — Phase 2 ---
STRIPE_SECRET_KEY=""
# Publishable key (pk_test_…) — served to the browser via GET /api/payments/config.
STRIPE_PUBLISHABLE_KEY=""
# From `stripe listen --forward-to localhost:3001/api/payments/webhook` (whsec_…).
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_CLIENT_ID=""
PLATFORM_FEE_BPS="1800"
PROVIDER_DEPOSIT_CENTS="5000"
# Require a provider to fund the $50 deposit before they can CLAIM jobs. Off by default
# so dev/demo/E2E providers (which never pay a deposit) can still claim; turn on in prod.
# When on, the deposit is also the primary source for strike/claw-back deductions.
REQUIRE_DEPOSIT_TO_CLAIM="false"

# --- Accountability (Sprint 4) ---
# Flat penalty deducted from a provider's next payout when they claim a job and then
# no-show (plus a strike). Product range is $15–25; any value is clamped to that range.
PROVIDER_NO_SHOW_FEE_CENTS="2000"
# Auto-detect providers who claimed a job and never showed. Off by default so it never
# surprises a demo; admins can always trigger it via POST /api/admin/no-shows/sweep.
NO_SHOW_SWEEP_ENABLED="false"
NO_SHOW_SWEEP_INTERVAL_MINUTES="5"
# A claimed job with no arrival after this many minutes is treated as a provider no-show
# (applies to both the auto-sweep and the admin-triggered sweep).
NO_SHOW_GRACE_MINUTES="30"
# Request the `tax_reporting_us_1099_k` capability on new Connect accounts so Stripe
# auto-generates each provider's year-end 1099-K. Set to "false" to opt out.
# (The platform must also enable 1099 tax reporting in the Stripe Dashboard:
#  Connect → Tax forms → enable 1099-K.)
STRIPE_1099K_ENABLED="true"

# --- Maps (Google) — Phase 3 ---
MAPS_PROVIDER="google"
# Server key: powers geocoding for the AI Pricing Engine's provider-pool distance and
# the live dynamic ETA. Without it, distance uses a default and ETA stays hidden.
GOOGLE_MAPS_SERVER_KEY=""
# Where the provider pool is dispatched from (origin for the pool→customer distance).
SERVICE_HUB_ADDRESS="Atlanta, GA"
# Per-mile trip fee applied to the provider-pool→customer distance in each estimate.
TRIP_FEE_PER_MILE_CENTS="150"

# --- Twilio SMS — Phase 4 ---
# Delivers every notification trigger (claim, en route, arrival, add-on, completion,
# payout, new-job, cancellation) AND phone-verification OTP as SMS. Enabled when SID +
# auth token + a sender (messaging service SID OR from-number) are set. Empty = graceful
# stub: messages are logged, in-app + realtime notifications are unaffected.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
TWILIO_MESSAGING_SERVICE_SID=""
# Require SMS OTP phone verification before proceeding. Off by default (seeded/E2E users
# are pre-verified); the OTP request/verify flow still works for testing when off.
PHONE_VERIFICATION_REQUIRED="false"
# "New job available" provider broadcast: service radius in miles from SERVICE_HUB_ADDRESS
# (Maps-gated; jobs beyond it don't broadcast) and the max providers notified per job.
PROVIDER_JOB_RADIUS_MILES="15"
PROVIDER_JOB_NOTIFY_LIMIT="25"

# --- Checkr background checks — Phase 4 ---
# With CHECKR_API_KEY set, provider background checks run through Checkr and status is
# driven by Checkr report webhooks (POST /api/webhooks/checkr). Empty = manual admin
# PASS/FAIL gate (backgroundCheckStatus stays STUB_PENDING until an admin decides).
CHECKR_API_KEY=""
CHECKR_WEBHOOK_SECRET=""

# --- App ---
PORT="3001"
APP_BASE_URL="http://localhost:5173"
# No email provider is wired yet, so the password-reset link is logged to the API
# console and (in non-production only) returned in the /auth/forgot-password
# response for testing. Set NODE_ENV=production to stop exposing the link.
# NODE_ENV="production"
